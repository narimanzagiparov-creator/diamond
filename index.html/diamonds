  },
];

let cart = [];
let currentProduct = null;

// ─── RENDER CATALOG ───
function formatPrice(p) {
  return p.toLocaleString('ru-RU') + ' ' + p.currency || '₸';
}

function renderProducts(filter = 'all') {
  const grid = document.getElementById('catalogGrid');
  grid.innerHTML = '';
  const filtered = products.filter(p => {
    if (filter === 'all') return true;
    if (filter === 'ring') return p.category === 'ring';
    if (filter === 'pendant') return p.category === 'pendant';
    if (filter === 'available') return p.status === 'available';
    if (filter === 'order') return p.status === 'order';
    return true;
  });
  filtered.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'product-card';
    card.style.animationDelay = (i * 0.08) + 's';
    card.dataset.category = p.category;
    const statusLabel = p.status === 'available' ? '<span class="product-status in-stock">В наличии</span>' : '<span class="product-status on-order">На заказ</span>';
    const orderTime = p.orderDays ? `<span class="order-time">⏱ ${p.orderDays}</span>` : '';
    card.innerHTML = `
      <div class="product-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        <div class="zoom-overlay"><div class="zoom-icon">🔍</div></div>
        ${statusLabel}
        ${orderTime}
      </div>
      <div class="product-info">
        <div class="product-category">${p.category === 'ring' ? 'Кольцо' : 'Подвеска'}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-specs">${p.specs.diamond} · ${p.specs.metal} · ${p.specs.cert}</div>
        <div class="product-price">${p.price.toLocaleString('ru-RU')} ₸<span>от ${Math.round(p.price/12).toLocaleString('ru-RU')} ₸/мес в рассрочку</span></div>
        <div class="product-actions">
          <button class="add-cart-btn" onclick="addToCart(${p.id}, event)">+ В корзину</button>
          <button class="view-btn" onclick="openModal(${p.id})">🔍</button>
        </div>
      </div>
    `;
    card.querySelector('.product-img-wrap').addEventListener('click', () => openModal(p.id));
    grid.appendChild(card);
  });
}

function filterProducts(filter, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(filter);
}

// ─── CART ───
function addToCart(id, e) {
  if (e) e.stopPropagation();
  const p = products.find(x => x.id === id);
  if (!p) return;
  const existing = cart.find(x => x.id === id);
  if (existing) { existing.qty++; } else { cart.push({...p, qty: 1}); }
  updateCartUI();
  showToast(`«${p.name}» добавлено в корзину`);
}

function addFromModal() {
  if (!currentProduct) return;
  addToCart(currentProduct.id, null);
  closeModalDirect();
}

function removeFromCart(id) {
  cart = cart.filter(x => x.id !== id);
  updateCartUI();
}

function updateCartUI() {
  const count = cart.reduce((s, x) => s + x.qty, 0);
  document.getElementById('cartCount').textContent = count;
  const itemsEl = document.getElementById('cartItems');
  const footerEl = document.getElementById('cartFooter');
  if (cart.length === 0) {
    itemsEl.innerHTML = '<div class="cart-empty">Корзина пуста</div>';
    footerEl.style.display = 'none';
    return;
  }
  footerEl.style.display = 'block';
  itemsEl.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}"/>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">${(item.price * item.qty).toLocaleString('ru-RU')} ₸${item.qty > 1 ? ` × ${item.qty}` : ''}</div>
      </div>
      <button class="cart-item-remove" onclick="removeFromCart(${item.id})">✕</button>
    </div>
  `).join('');
  const total = cart.reduce((s, x) => s + x.price * x.qty, 0);
  document.getElementById('cartTotal').textContent = total.toLocaleString('ru-RU') + ' ₸';
}

function toggleCart() {
  document.getElementById('cartSidebar').classList.toggle('open');
}

function checkout() {
  const total = cart.reduce((s, x) => s + x.price * x.qty, 0);
  const items = cart.map(x => `${x.name} (${x.qty} шт.)`).join(', ');
  const msg = encodeURIComponent(`Здравствуйте! Хочу оформить заказ:\n${items}\nИтого: ${total.toLocaleString('ru-RU')} ₸`);
  window.open(`https://wa.me/77019475000?text=${msg}`, '_blank');
}

// ─── MODAL ───
function openModal(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  currentProduct = p;
  document.getElementById('modalCategory').textContent = p.category === 'ring' ? 'Кольцо' : 'Подвеска';
  document.getElementById('modalName').textContent = p.name;
  document.getElementById('modalPrice').textContent = p.price.toLocaleString('ru-RU') + ' ₸';
  const statusEl = document.getElementById('modalStatus');
  if (p.status === 'available') {
    statusEl.textContent = '✓ В наличии'; statusEl.style.background = 'rgba(76,175,80,0.2)'; statusEl.style.color = '#81c784'; statusEl.style.border = '1px solid rgba(76,175,80,0.3)';
  } else {
    statusEl.textContent = `⏱ На заказ · ${p.orderDays}`; statusEl.style.background = 'rgba(200,168,75,0.15)'; statusEl.style.color = '#C8A84B'; statusEl.style.border = '1px solid rgba(200,168,75,0.3)';
  }
  const specsEl = document.getElementById('modalSpecs');
  specsEl.innerHTML = Object.entries({
    'Металл': p.specs.metal,
    'Бриллиант': p.specs.diamond,
    'Огранка': p.specs.cut,
    'Цвет': p.specs.color,
    'Чистота': p.specs.clarity,
    'Сертификат': p.specs.cert
  }).map(([k, v]) => `<div class="spec-row"><span>${k}</span><strong>${v}</strong></div>`).join('');
  document.getElementById('modalImg').src = p.img;
  document.getElementById('modalImg').alt = p.name;
  document.getElementById('modalImg').classList.remove('zoomed');
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModalDirect();
}
function closeModalDirect() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
  currentProduct = null;
}

function toggleZoom(img) {
  img.classList.toggle('zoomed');
}

// ─── TOAST ───
function showToast(msg) {
  const t = document.createElement('div');
  t.style.cssText = `position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#6B3FA0,#8B52CC);color:white;padding:12px 28px;border-radius:4px;font-size:0.72rem;letter-spacing:0.1em;z-index:9999;animation:fadeInUp 0.3s ease;box-shadow:0 8px 30px rgba(107,63,160,0.4);`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2500);
}

// ─── SCROLL REVEAL ───
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.guide-card, .pay-card, .compare-card, .contact-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(30px)';
  el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
  observer.observe(el);
});

// ─── INIT ───
renderProducts();
</script>
