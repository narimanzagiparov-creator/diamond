<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GEKKEL JEWELLERY — Бриллиантовые украшения</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --deep-violet: #2D1B4E;
  --royal-purple: #6B3FA0;
  --soft-lavender: #C9A8E8;
  --light-lilac: #EEE0FA;
  --gold: #C8A84B;
  --gold-light: #E8D08A;
  --white: #FDFAFF;
  --text-dark: #1A0F2E;
  --text-mid: #4A3570;
  --glass: rgba(255,255,255,0.07);
  --glass-border: rgba(200,168,75,0.3);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Montserrat', sans-serif;
  background: var(--deep-violet);
  color: var(--white);
  overflow-x: hidden;
}

/* ─── PARTICLES CANVAS ─── */
#particles-canvas {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none; z-index: 0;
  opacity: 0.4;
}

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 20px 60px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(45,27,78,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
}

.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 500;
  letter-spacing: 0.25em;
  color: var(--gold);
  text-decoration: none;
}

.nav-links {
  display: flex; gap: 36px; list-style: none;
}
.nav-links a {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--soft-lavender);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--gold); }

.nav-actions { display: flex; align-items: center; gap: 16px; }

.cart-btn {
  position: relative;
  background: none; border: 1px solid var(--glass-border);
  color: var(--gold); padding: 8px 20px;
  border-radius: 2px; cursor: pointer;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.7rem; letter-spacing: 0.15em;
  text-transform: uppercase; transition: all 0.3s;
}
.cart-btn:hover { background: var(--gold); color: var(--deep-violet); }
.cart-count {
  position: absolute; top: -8px; right: -8px;
  background: var(--royal-purple); color: white;
  border-radius: 50%; width: 18px; height: 18px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem; font-weight: 600;
}

/* ─── HERO ─── */
.hero {
  position: relative; height: 100vh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 60% 40%, #5A2A8A 0%, #2D1B4E 50%, #1A0A30 100%);
}

.hero-ring-3d {
  position: absolute; right: 10%; top: 50%;
  transform: translateY(-50%);
  width: 500px; height: 500px;
}

.ring-scene {
  width: 100%; height: 100%;
  animation: float3d 6s ease-in-out infinite;
}

@keyframes float3d {
  0%,100% { transform: translateY(0) rotateY(0deg) rotateX(5deg); }
  25% { transform: translateY(-20px) rotateY(15deg) rotateX(8deg); }
  50% { transform: translateY(-10px) rotateY(5deg) rotateX(3deg); }
  75% { transform: translateY(-25px) rotateY(-10deg) rotateX(10deg); }
}

.hero-content {
  position: relative; z-index: 2;
  max-width: 600px; padding: 0 60px;
}

.hero-eyebrow {
  font-size: 0.7rem; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 12px;
}
.hero-eyebrow::before {
  content: ''; display: block;
  width: 40px; height: 1px; background: var(--gold);
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 300;
  line-height: 1.05;
  color: var(--white);
  margin-bottom: 24px;
}
.hero-title em {
  font-style: italic;
  color: var(--soft-lavender);
}

.hero-subtitle {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  color: var(--soft-lavender);
  line-height: 1.8;
  margin-bottom: 40px;
  opacity: 0.85;
}

.hero-ctas {
  display: flex; gap: 16px; flex-wrap: wrap;
}

.btn-primary {
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--deep-violet);
  padding: 14px 36px; border: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase;
  cursor: pointer; border-radius: 2px;
  transition: all 0.3s; text-decoration: none;
  display: inline-block;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(200,168,75,0.4);
}

.btn-outline {
  background: transparent;
  color: var(--soft-lavender);
  padding: 14px 36px;
  border: 1px solid rgba(201,168,232,0.4);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; font-weight: 400;
  letter-spacing: 0.2em; text-transform: uppercase;
  cursor: pointer; border-radius: 2px;
  transition: all 0.3s; text-decoration: none;
  display: inline-block;
}
.btn-outline:hover {
  border-color: var(--soft-lavender);
  background: rgba(201,168,232,0.1);
  transform: translateY(-2px);
}

.hero-badges {
  position: absolute; bottom: 40px; left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 40px;
  z-index: 2;
}
.badge {
  text-align: center;
  animation: fadeInUp 1s ease both;
}
.badge:nth-child(2) { animation-delay: 0.15s; }
.badge:nth-child(3) { animation-delay: 0.3s; }
.badge:nth-child(4) { animation-delay: 0.45s; }

.badge-icon {
  font-size: 1.4rem; margin-bottom: 6px;
}
.badge-text {
  font-size: 0.62rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--soft-lavender);
}

@keyframes fadeInUp {
  from { opacity:0; transform:translateY(20px); }
  to { opacity:1; transform:translateY(0); }
}

/* ─── SECTION COMMON ─── */
section { position: relative; z-index: 1; }

.section-header {
  text-align: center;
  padding: 80px 60px 50px;
}
.section-eyebrow {
  font-size: 0.65rem; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 14px;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.4rem);
  font-weight: 300; color: var(--white);
}
.section-title em { font-style: italic; color: var(--soft-lavender); }
.divider {
  width: 60px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 20px auto 0;
}

/* ─── FILTER TABS ─── */
.filter-tabs {
  display: flex; justify-content: center; gap: 8px;
  padding: 0 60px 40px; flex-wrap: wrap;
}
.tab-btn {
  background: none;
  border: 1px solid rgba(201,168,232,0.25);
  color: var(--soft-lavender);
  padding: 9px 24px;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.68rem; letter-spacing: 0.15em;
  text-transform: uppercase; cursor: pointer;
  border-radius: 2px; transition: all 0.3s;
}
.tab-btn.active, .tab-btn:hover {
  background: var(--royal-purple);
  border-color: var(--royal-purple);
  color: white;
}

/* ─── CATALOG GRID ─── */
.catalog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px; padding: 0 60px 80px;
}

.product-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: 4px;
  overflow: hidden;
  transition: all 0.4s;
  cursor: pointer;
  animation: fadeInUp 0.6s ease both;
}
.product-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 60px rgba(107,63,160,0.4);
  border-color: var(--gold);
}

.product-img-wrap {
  position: relative; overflow: hidden;
  aspect-ratio: 1/1; background: #1a0f2e;
}

.product-img-wrap img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.5s;
}
.product-card:hover .product-img-wrap img {
  transform: scale(1.06);
}

/* Zoom overlay */
.zoom-overlay {
  position: absolute; inset: 0;
  background: rgba(45,27,78,0.7);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.3s;
}
.product-card:hover .zoom-overlay { opacity: 1; }
.zoom-icon {
  color: white; font-size: 1.8rem;
  background: rgba(255,255,255,0.15);
  width: 50px; height: 50px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid rgba(255,255,255,0.3);
}

.product-status {
  position: absolute; top: 14px; left: 14px;
  font-size: 0.6rem; letter-spacing: 0.15em;
  text-transform: uppercase; padding: 5px 12px;
  border-radius: 2px; font-weight: 600;
}
.in-stock { background: rgba(76,175,80,0.85); color: white; }
.on-order { background: rgba(200,168,75,0.85); color: #1a0f2e; }
.order-time {
  position: absolute; top: 14px; right: 14px;
  font-size: 0.58rem; letter-spacing: 0.1em;
  background: rgba(45,27,78,0.8);
  color: var(--soft-lavender);
  padding: 4px 10px; border-radius: 2px;
  border: 1px solid rgba(201,168,232,0.3);
}

.product-info { padding: 20px; }
.product-category {
  font-size: 0.6rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 6px;
}
.product-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem; font-weight: 400;
  color: var(--white); margin-bottom: 6px;
}
.product-specs {
  font-size: 0.65rem; color: var(--soft-lavender);
  line-height: 1.6; margin-bottom: 14px;
  opacity: 0.8;
}
.product-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem; font-weight: 500;
  color: var(--gold); margin-bottom: 16px;
}
.product-price span {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.65rem; color: var(--soft-lavender);
  display: block; margin-top: 2px;
}

.product-actions {
  display: flex; gap: 8px;
}
.add-cart-btn {
  flex: 1;
  background: linear-gradient(135deg, var(--royal-purple), #8B52CC);
  color: white; border: none;
  padding: 10px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.65rem; letter-spacing: 0.15em;
  text-transform: uppercase; cursor: pointer;
  border-radius: 2px; transition: all 0.3s;
}
.add-cart-btn:hover {
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--deep-violet);
  transform: scale(1.02);
}
.view-btn {
  background: none;
  border: 1px solid var(--glass-border);
  color: var(--gold); padding: 10px 14px;
  cursor: pointer; border-radius: 2px;
  font-size: 0.75rem; transition: all 0.3s;
}
.view-btn:hover { background: rgba(200,168,75,0.1); }

/* ─── PAYMENT SECTION ─── */
.payment-section {
  padding: 80px 60px;
  background: linear-gradient(180deg, transparent, rgba(107,63,160,0.1), transparent);
}
.payment-title {
  text-align: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.4rem; font-weight: 300;
  color: var(--white); margin-bottom: 50px;
}
.payment-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
}
.pay-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  padding: 32px 28px; border-radius: 4px;
  text-align: center; transition: all 0.4s;
}
.pay-card:hover {
  border-color: var(--gold);
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(200,168,75,0.15);
}
.pay-icon { font-size: 2.2rem; margin-bottom: 16px; }
.pay-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.25rem; color: var(--gold);
  margin-bottom: 10px;
}
.pay-desc {
  font-size: 0.7rem; color: var(--soft-lavender);
  line-height: 1.7; opacity: 0.85;
}

/* ─── GUIDE SECTION ─── */
.guide-section {
  padding: 80px 60px;
}
.guide-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px; margin-top: 20px;
}
.guide-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  padding: 32px; border-radius: 4px;
  transition: all 0.4s;
}
.guide-card:hover {
  border-color: var(--soft-lavender);
  transform: translateY(-4px);
}
.guide-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3.5rem; font-weight: 300;
  color: rgba(201,168,232,0.2);
  line-height: 1; margin-bottom: 16px;
}
.guide-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem; color: var(--gold);
  margin-bottom: 12px;
}
.guide-text {
  font-size: 0.72rem; color: var(--soft-lavender);
  line-height: 1.8; opacity: 0.85;
}

/* ─── DIAMONDS COMPARE ─── */
.compare-section {
  padding: 80px 60px;
  background: rgba(107,63,160,0.07);
}
.compare-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px; max-width: 900px; margin: 40px auto 0;
}
.compare-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  padding: 36px; border-radius: 4px;
  text-align: center;
}
.compare-card.natural { border-top: 3px solid var(--gold); }
.compare-card.lab { border-top: 3px solid var(--royal-purple); }
.compare-icon { font-size: 2.5rem; margin-bottom: 16px; }
.compare-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem; margin-bottom: 8px;
}
.compare-card.natural .compare-name { color: var(--gold); }
.compare-card.lab .compare-name { color: var(--soft-lavender); }
.compare-list {
  list-style: none;
  text-align: left; margin-top: 20px;
}
.compare-list li {
  font-size: 0.72rem; color: var(--soft-lavender);
  padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
  line-height: 1.6; display: flex; gap: 10px;
}
.compare-list li::before { content: '◆'; color: var(--gold); font-size: 0.5rem; margin-top: 4px; flex-shrink: 0; }

/* ─── CONTACT / FOOTER ─── */
.contact-section {
  padding: 80px 60px;
  text-align: center;
}
.contact-links {
  display: flex; justify-content: center;
  gap: 24px; margin-top: 40px; flex-wrap: wrap;
}
.contact-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  padding: 28px 36px; border-radius: 4px;
  text-decoration: none; color: inherit;
  transition: all 0.3s; min-width: 200px;
}
.contact-card:hover {
  border-color: var(--gold);
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(200,168,75,0.15);
}
.contact-icon { font-size: 1.8rem; margin-bottom: 10px; }
.contact-label {
  font-size: 0.62rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 6px;
}
.contact-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem; color: var(--white);
}

footer {
  border-top: 1px solid var(--glass-border);
  padding: 30px 60px;
  display: flex; justify-content: space-between;
  align-items: center; font-size: 0.65rem;
  color: rgba(201,168,232,0.5);
  letter-spacing: 0.1em;
  flex-wrap: wrap; gap: 12px;
}

/* ─── MODAL ─── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(26,15,46,0.92);
  backdrop-filter: blur(16px);
  z-index: 2000;
  display: none; align-items: center; justify-content: center;
  padding: 20px;
}
.modal-overlay.open { display: flex; }
.modal {
  background: linear-gradient(135deg, #2D1B4E, #1E1235);
  border: 1px solid var(--glass-border);
  border-radius: 6px;
  max-width: 900px; width: 100%;
  max-height: 90vh; overflow-y: auto;
  display: grid; grid-template-columns: 1fr 1fr;
  position: relative;
  animation: modalIn 0.4s ease;
}
@keyframes modalIn {
  from { opacity:0; transform:scale(0.93) translateY(20px); }
  to { opacity:1; transform:scale(1) translateY(0); }
}
.modal-close {
  position: absolute; top: 16px; right: 16px;
  background: none; border: 1px solid var(--glass-border);
  color: var(--soft-lavender); width: 34px; height: 34px;
  border-radius: 50%; cursor: pointer;
  font-size: 1rem; display: flex;
  align-items: center; justify-content: center;
  transition: all 0.3s; z-index: 10;
}
.modal-close:hover { background: var(--royal-purple); }

.modal-img-wrap {
  position: relative; overflow: hidden;
  border-radius: 6px 0 0 6px;
}
.modal-img-wrap img {
  width: 100%; height: 100%; object-fit: cover;
  cursor: zoom-in; transition: transform 0.3s;
}
.modal-img-wrap img.zoomed {
  transform: scale(1.8);
  cursor: zoom-out;
}
.zoom-hint {
  position: absolute; bottom: 14px; left: 50%;
  transform: translateX(-50%);
  background: rgba(45,27,78,0.8);
  color: var(--soft-lavender);
  font-size: 0.6rem; padding: 5px 12px;
  border-radius: 20px; letter-spacing: 0.1em;
  pointer-events: none;
}
.modal-details { padding: 40px; }
.modal-category {
  font-size: 0.6rem; letter-spacing: 0.25em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 10px;
}
.modal-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem; font-weight: 300;
  color: var(--white); margin-bottom: 14px;
}
.modal-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem; color: var(--gold);
  margin-bottom: 20px;
}
.modal-specs {
  border-top: 1px solid var(--glass-border);
  border-bottom: 1px solid var(--glass-border);
  padding: 16px 0; margin-bottom: 20px;
}
.spec-row {
  display: flex; justify-content: space-between;
  padding: 6px 0; font-size: 0.7rem;
  color: var(--soft-lavender);
}
.spec-row strong { color: var(--white); }

.modal-status {
  display: inline-block; font-size: 0.62rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  padding: 5px 14px; border-radius: 2px;
  margin-bottom: 20px;
}
.modal-add-btn {
  width: 100%; padding: 14px;
  background: linear-gradient(135deg, var(--royal-purple), #8B52CC);
  color: white; border: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; letter-spacing: 0.2em;
  text-transform: uppercase; cursor: pointer;
  border-radius: 2px; transition: all 0.3s;
  margin-bottom: 10px;
}
.modal-add-btn:hover {
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--deep-violet);
}
.modal-wa-btn {
  width: 100%; padding: 12px;
  background: transparent;
  color: #25D366; border: 1px solid #25D366;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.68rem; letter-spacing: 0.15em;
  text-transform: uppercase; cursor: pointer;
  border-radius: 2px; transition: all 0.3s;
}
.modal-wa-btn:hover { background: rgba(37,211,102,0.1); }

/* ─── CART SIDEBAR ─── */
.cart-sidebar {
  position: fixed; top: 0; right: -420px;
  width: 420px; height: 100%;
  background: linear-gradient(180deg, #2D1B4E, #1E1235);
  border-left: 1px solid var(--glass-border);
  z-index: 3000; transition: right 0.4s ease;
  display: flex; flex-direction: column;
  backdrop-filter: blur(20px);
}
.cart-sidebar.open { right: 0; }
.cart-header {
  padding: 24px 28px;
  border-bottom: 1px solid var(--glass-border);
  display: flex; justify-content: space-between;
  align-items: center;
}
.cart-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem; color: var(--gold);
}
.cart-close {
  background: none; border: 1px solid var(--glass-border);
  color: var(--soft-lavender); width: 32px; height: 32px;
  border-radius: 50%; cursor: pointer; font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s;
}
.cart-close:hover { background: var(--royal-purple); }
.cart-items { flex: 1; overflow-y: auto; padding: 20px 28px; }
.cart-empty {
  text-align: center; padding: 60px 0;
  color: var(--soft-lavender); opacity: 0.5;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
}
.cart-item {
  display: flex; gap: 14px;
